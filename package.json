{
  "name": "airport-data-js",
  "version": "3.1.0",
  "type": "commonjs",
  "description": "A comprehensive TypeScript library providing easy retrieval of airport data based on IATA, ICAO, city codes, country codes, and continents. Includes LLM tool definitions for AI integration.",
  "main": "lib/index.js",
  "types": "types/index.d.ts",
  "browser": "dist/airport-data.min.js",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "require": "./lib/index.js",
      "default": "./lib/index.js"
    },
    "./tools": {
      "types": "./types/tools.d.ts",
      "require": "./lib/tools.js",
      "default": "./lib/tools.js"
    }
  },
  "files": [
    "lib/",
    "dist/",
    "types/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "test": "jest --config jest.config.cjs",
    "typecheck": "tsc --noEmit",
    "build:types": "tsc --emitDeclarationOnly",
    "build:lib": "webpack --config webpack.node.cjs",
    "build:dist": "webpack --config webpack.browser.cjs",
    "build:tools": "webpack --config webpack.tools.cjs",
    "build": "npm run build:types && npm run build:lib && npm run build:dist && npm run build:tools",
    "check:duplicates": "node scripts/check_duplicates.js"
  },
  "dependencies": {
    "jsonpack": "^1.1.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aashishvanand/airport-data-js.git"
  },
  "keywords": [
    "airport",
    "airports",
    "iata",
    "icao",
    "flight",
    "flightradar24",
    "flightaware",
    "radarbox",
    "aviation",
    "travel",
    "geography",
    "codes",
    "continent",
    "city",
    "country",
    "aircodes",
    "amadeus",
    "ISOCountryCodes",
    "FAA",
    "timezones"
  ],
  "author": "Aashish Vivekanand",
  "license": "CC BY 4.0",
  "bugs": {
    "url": "https://github.com/aashishvanand/airport-data-js/issues"
  },
  "homepage": "https://airportdata.dev/",
  "overrides": {
    "brace-expansion@1": "^1.1.14",
    "brace-expansion@2": "^2.1.0",
    "ajv@8": "^8.18.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.6",
    "@babel/plugin-transform-modules-commonjs": "^7.28.6",
    "@babel/preset-env": "^7.28.6",
    "@types/jest": "^30.0.0",
    "babel-jest": "^30.2.0",
    "babel-loader": "^10.0.0",
    "csv-parse": "^6.1.0",
    "fs-extra": "^11.3.3",
    "jest": "^30.2.0",
    "path-browserify": "^1.0.1",
"ts-jest": "^29.4.9",
    "ts-loader": "^9.5.1",
    "typescript": "^6.0.3",
    "webpack": "^5.104.1",
    "webpack-cli": "^7.0.2"
  }
}
